{
	"name": "tailflare",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"deploy": "turbo run deploy",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"wasm:build": "turbo run wasm:build --filter=@tailflare/tailscale-wasm"
	},
	"devDependencies": {
		"turbo": "^2.9.6",
		"typescript": "^5.5.2"
	},
	"packageManager": "bun@1.3.13"
}
